title: $:/wikilabs/ui/TiddlerInfo/TagMap/ItemTemplate

\whitespace trim
<div class="tc-menu-list-item">
	<$link to=<<currentTiddler>>>
		<$view field="title"/>
	</$link>
	<%if [<currentTiddler>has:field[list-before]] %>
		<span class="wltc-list-pos" title={{{ [[list-before: ]addsuffix{!!list-before}] }}}>↑</span>
	<%endif%>
	<%if [<currentTiddler>has:field[list-after]] %>
		<span class="wltc-list-pos" title={{{ [[list-after: ]addsuffix{!!list-after}] }}}>↓</span>
	<%endif%>
</div>
