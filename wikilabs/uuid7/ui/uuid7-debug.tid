title: $:/plugins/wikilabs/uuid7/ui/uuid7-debug
caption: UUID7 Debug

\procedure uuid7-bit-table(uuidValue)
\whitespace trim
<$let
	hex={{{ [<uuidValue>search-replace:g:literal[-],[]] }}}
>

! UUID v7 Hex Encoding Breakdown

''c7:'' <code><$text text=<<uuidValue>>/></code>

''c32:'' <code><$text text={{{ [<uuidValue>uuid7[c32]] }}}/></code> ''check:'' <code><$text text={{{ [<uuidValue>uuid7[check]] }}}/></code>

