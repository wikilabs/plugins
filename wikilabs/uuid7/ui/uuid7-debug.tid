''Timestamp:'' <$text text={{{ [<uuidValue>uuid7[ms]] }}}/> ms — <$text text={{{ [<uuidValue>uuid7[ms]format:timestamp[YYYY-0MM-0DD 0hh:0mm:0ss.XXX]] }}}/>

''Version:'' <$text text={{{ [<uuidValue>uuid7[version]] }}}/> — ''Variant:'' <$text text={{{ [<uuidValue>uuid7[variant]] }}}/> — ''Random:'' <code><$text text={{{ [<uuidValue>uuid7[rnd]] }}}/></code>

!! Table 2: Comparison UUID hex vs Crockford Base32

<table>
<tr>
	<th></th>
	<th>c7 (UUID hex)</th>
	<th>c32 (Crockford Base32)</th>
</tr>
<tr>
	<td>''Value''</td>
	<td><code><$text text=<<uuidValue>>/></code></td>
	<td><code><$text text={{{ [<uuidValue>uuid7[c32]] }}}/></code></td>
</tr>
<tr>
	<td>''Length''</td>
	<td>36 chars</td>
	<td>29 chars</td>
</tr>
<tr>
	<td>''Chars''</td>
	<td>32 hex + 4 hyphens</td>
	<td>26 base32 + 3 hyphens</td>
</tr>
<tr>
	<td>''Bits/char''</td>
	<td>4</td>
	<td>5</td>
</tr>
<tr>
	<td>''Alphabet''</td>
	<td><code>0-9a-f</code></td>
	<td><code>0-9A-Z</code> (no I,L,O,U)</td>
</tr>
<tr>
	<td>''Sortable''</td>
	<td>Yes</td>
	<td>Yes</td>
</tr>
</table>

!! Phrase encoding

<$text text={{{ [<uuidValue>uuid7[phrase]] }}}/>

</$let>
\end

Enter a UUID v7 or c32 value to inspect:

<$edit-text tiddler="$:/temp/uuid7-debug-input" field="text" tag="input" default="" placeholder="UUID v7 hex or c32 value" size="40"/>

<$let
	userInput={{{ [[$:/temp/uuid7-debug-input]get[text]trim[]] }}}
	isUUID={{{ [<userInput>uuid7[valid]] }}}
	asC32={{{ [<userInput>search-replace:g:literal[-],[]c32[]] }}}
	inputVal={{{ [<isUUID>match[yes]then<userInput>] ~[<asC32>length[]match[26]then<asC32>c32[c7]] }}}
>
<%if [<inputVal>uuid7[valid]match[yes]] %>
	<$macrocall $name="uuid7-bit-table" uuidValue=<<inputVal>>/>
<%elseif [<userInput>length[]compare:number:gt[0]] %>
	//Enter a valid UUID v7 or c32 value//
<%else%>

---

Or inspect the current tiddler's c7 field:

<$list filter="[all[current]has[c7]]" variable="t" emptyMessage="//This tiddler has no c7 field. Enter a value above.//">
	<$macrocall $name="uuid7-bit-table" uuidValue={{{ [all[current]get[c7]] }}}/>
</$list>

<%endif%>
</$let>
