title: $:/plugins/wikilabs/uuid7/ui/uuid7-debug
caption: UUID7 Debug

\whitespace trim

\procedure uuid7-bit-table(uuidValue)
\whitespace trim
<$let
	hex={{{ [<uuidValue>search-replace:g:literal[-],[]] }}}
>

! UUID v7 Hex Encoding Breakdown

''c7:'' <code><$text text=<<uuidValue>>/></code>

''c32:'' <code><$text text={{{ [<uuidValue>uuid7[c32]] }}}/></code> ''check:'' <code><$text text={{{ [<uuidValue>uuid7[check]] }}}/></code>

!! Table 1: UUID v7 hex layout (8-4-4-4-12)

<table>
<tr>
	<th>Hex</th>
	<$list filter="[<hex>split[]first[8]]" variable="ch">
		<td style="text-align:center; font-weight:bold;"><$text text=<<ch>>/></td>
	</$list>
	<td style="text-align:center;">-</td>
	<$list filter="[<hex>split[]rest[8]first[4]]" variable="ch">
		<td style="text-align:center; font-weight:bold;"><$text text=<<ch>>/></td>
	</$list>
	<td style="text-align:center;">-</td>
	<$list filter="[<hex>split[]rest[12]first[4]]" variable="ch">
		<td style="text-align:center; font-weight:bold;"><$text text=<<ch>>/></td>
	</$list>
	<td style="text-align:center;">-</td>
	<$list filter="[<hex>split[]rest[16]first[4]]" variable="ch">
		<td style="text-align:center; font-weight:bold;"><$text text=<<ch>>/></td>
	</$list>
	<td style="text-align:center;">-</td>
	<$list filter="[<hex>split[]rest[20]]" variable="ch">
		<td style="text-align:center; font-weight:bold;"><$text text=<<ch>>/></td>
	</$list>
</tr>
<tr>
	<th>Decimal</th>
	<$list filter="[<hex>split[]first[8]]" variable="ch">
		<td style="text-align:center;"><$text text={{{ [<ch>uuid7[value]] }}}/></td>
	</$list>
	<td></td>
	<$list filter="[<hex>split[]rest[8]first[4]]" variable="ch">
		<td style="text-align:center;"><$text text={{{ [<ch>uuid7[value]] }}}/></td>
	</$list>
	<td></td>
	<$list filter="[<hex>split[]rest[12]first[4]]" variable="ch">
		<td style="text-align:center;"><$text text={{{ [<ch>uuid7[value]] }}}/></td>
	</$list>
	<td></td>
	<$list filter="[<hex>split[]rest[16]first[4]]" variable="ch">
		<td style="text-align:center;"><$text text={{{ [<ch>uuid7[value]] }}}/></td>
	</$list>
	<td></td>
	<$list filter="[<hex>split[]rest[20]]" variable="ch">
		<td style="text-align:center;"><$text text={{{ [<ch>uuid7[value]] }}}/></td>
	</$list>
</tr>
<tr>
	<th>Binary</th>
	<$list filter="[<hex>split[]first[8]]" variable="ch">
		<td style="text-align:center; font-family:monospace; font-size:0.8em;"><$text text={{{ [<ch>uuid7[bits]] }}}/></td>
	</$list>
	<td></td>
	<$list filter="[<hex>split[]rest[8]first[4]]" variable="ch">
		<td style="text-align:center; font-family:monospace; font-size:0.8em;"><$text text={{{ [<ch>uuid7[bits]] }}}/></td>
	</$list>
	<td></td>
	<$list filter="[<hex>split[]rest[12]first[4]]" variable="ch">
		<td style="text-align:center; font-family:monospace; font-size:0.8em;"><$text text={{{ [<ch>uuid7[bits]] }}}/></td>
	</$list>
	<td></td>
	<$list filter="[<hex>split[]rest[16]first[4]]" variable="ch">
		<td style="text-align:center; font-family:monospace; font-size:0.8em;"><$text text={{{ [<ch>uuid7[bits]] }}}/></td>
	</$list>
	<td></td>
	<$list filter="[<hex>split[]rest[20]]" variable="ch">
		<td style="text-align:center; font-family:monospace; font-size:0.8em;"><$text text={{{ [<ch>uuid7[bits]] }}}/></td>
	</$list>
</tr>
<tr>
	<th>Group</th>
	<td style="text-align:center; background:#b8e6b8;" colspan="8">timestamp high (32 bits)</td>
	<td></td>
	<td style="text-align:center; background:#b8c8e6;" colspan="4">timestamp low (16 bits)</td>
	<td></td>
	<td style="text-align:center; background:#d8b8e6;" colspan="4">ver (4) + rand_a (12)</td>
